{
  "enabled": true,
  "name": "Credential Guard",
  "description": "Block writes containing hardcoded credentials. Shift-left secret detection before code is written.",
  "version": "1",
  "when": {
    "type": "preToolUse",
    "toolTypes": ["write"]
  },
  "then": {
    "type": "runCommand",
    "command": ".kiro/hooks/scripts/scan-credentials.sh"
  }
}
