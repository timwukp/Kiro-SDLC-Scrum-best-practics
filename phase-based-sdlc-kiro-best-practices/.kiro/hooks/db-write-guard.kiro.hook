{
  "enabled": true,
  "name": "DB Write Guard",
  "description": "Block dangerous SQL mutation statements (INSERT/UPDATE/DELETE/DROP). Database changes must go through Flyway migrations.",
  "version": "1",
  "when": {
    "type": "preToolUse",
    "toolTypes": ["shell", "@aurora-dsql"]
  },
  "then": {
    "type": "runCommand",
    "command": ".kiro/hooks/scripts/validate-sql-readonly.sh"
  }
}
